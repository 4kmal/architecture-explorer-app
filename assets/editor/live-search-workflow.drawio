          </mxCell>
        </object>
        <object id="live-comparison-daily" label="&lt;b&gt;Daily Index&lt;/b&gt;&lt;br&gt;Public · last scheduled snapshot&lt;br&gt;No upstream request per user search&lt;br&gt;60 s serving cache · reads public.scraped_jobs&lt;br&gt;Refreshed at 02:00 UTC or manual run" labelEn="&lt;b&gt;Daily Index&lt;/b&gt;&lt;br&gt;Public · last scheduled snapshot&lt;br&gt;No upstream request per user search&lt;br&gt;60 s serving cache · reads public.scraped_jobs&lt;br&gt;Refreshed at 02:00 UTC or manual run" labelMs="&lt;b&gt;Indeks Harian&lt;/b&gt;&lt;br&gt;Awam · snapshot berjadual terakhir&lt;br&gt;Tiada permintaan huluan bagi setiap carian&lt;br&gt;Cache penyampaian 60 s · baca public.scraped_jobs&lt;br&gt;Disegar pada 02:00 UTC atau larian manual" petakerjaKey="live-search-workflow/comparison-daily" workflowRole="comparison-column">
          <mxCell parent="1" vertex="1" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=light-dark(#ecfdf3,#17291f);strokeColor=light-dark(#68b88a,#4f9e73);strokeWidth=1;fontColor=light-dark(#14532d,#d8f7e5);fontFamily=Arial;fontSize=12;align=left;verticalAlign=top;spacing=12;">
