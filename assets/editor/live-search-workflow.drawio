        <object id="live-comparison-live" label="&lt;b&gt;Live Search&lt;/b&gt;&lt;br&gt;Sign-in required · queries sources now&lt;br&gt;Up to 8 upstream requests on cache miss&lt;br&gt;5 min per-filter cache + single-flight&lt;br&gt;7 s timeout/source · no job-table access" labelEn="&lt;b&gt;Live Search&lt;/b&gt;&lt;br&gt;Sign-in required · queries sources now&lt;br&gt;Up to 8 upstream requests on cache miss&lt;br&gt;5 min per-filter cache + single-flight&lt;br&gt;7 s timeout/source · no job-table access" labelMs="&lt;b&gt;Carian Langsung&lt;/b&gt;&lt;br&gt;Log masuk diperlukan · sumber ditanya sekarang&lt;br&gt;Sehingga 8 permintaan huluan apabila cache luput&lt;br&gt;Cache setiap penapis 5 min + single-flight&lt;br&gt;Had masa 7 s/sumber · tiada akses jadual kerja" petakerjaKey="live-search-workflow/comparison-live" workflowRole="comparison-column">
          <mxCell parent="1" vertex="1" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=light-dark(#eef4ff,#182338);strokeColor=light-dark(#7ea6df,#5e83ba);strokeWidth=1;fontColor=light-dark(#17375e,#e8f1ff);fontFamily=Arial;fontSize=12;align=left;verticalAlign=top;spacing=12;">
